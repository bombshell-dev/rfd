---
import type { ActorIdentifier } from '@atcute/lexicons/syntax';

import { getDiscussionRepo, NoDiscussionRepoError } from '../lib/discussion.ts';

export const prerender = false;

const { handle } = Astro.params;

let view;
let error: string | null = null;
try {
  view = await getDiscussionRepo(handle as ActorIdentifier);
} catch (err) {
  if (err instanceof NoDiscussionRepoError) {
    Astro.response.status = 404;
    error = err.message;
  } else {
    Astro.response.status = 500;
    error = err instanceof Error ? err.message : String(err);
  }
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{view ? `${view.repo.name} — st.itch` : `${handle} — st.itch`}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <header>
      <a href="/">st.itch</a>
    </header>
    <main>
      {error && <p role="alert">{error}</p>}
      {view && (
        <article>
          <h1>{view.repo.name}</h1>
          <p>
            <strong>{view.repo.owner.handle ?? view.repo.owner.did}</strong>
            {' · '}
            <code>{view.repo.knot}</code>
          </p>
          {view.repo.description && <p>{view.repo.description}</p>}
          <dl>
            <dt>Discussion repo</dt>
            <dd><code>{view.claim.repo}</code></dd>
            <dt>Claimed at</dt>
            <dd><time datetime={view.claim.createdAt}>{view.claim.createdAt}</time></dd>
            <dt>Repo created</dt>
            <dd><time datetime={view.repo.createdAt}>{view.repo.createdAt}</time></dd>
          </dl>
          <p>
            <em>RFD list coming soon — cross-author aggregation needs an indexer. View on
            <a href={`https://tangled.org/${view.repo.owner.handle ?? view.repo.owner.did}/${view.repo.name}`}>tangled.org</a>.</em>
          </p>
        </article>
      )}
    </main>
  </body>
</html>
