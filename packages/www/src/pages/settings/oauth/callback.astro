<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Signing in… — st.itch</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <main>
      <p id="status">Finishing sign-in…</p>
      <p id="error" role="alert" hidden></p>
    </main>
    <script>
      import { configure, finishLogin } from '../../../lib/oauth.ts';
      const status = document.getElementById('status');
      const error = document.getElementById('error');
      try {
        configure();
        const session = await finishLogin();
        sessionStorage.setItem('rfd:did', session.info.sub);
        location.replace('/settings/claim');
      } catch (err) {
        status.hidden = true;
        error.textContent = `Sign-in failed: ${err?.message ?? String(err)}`;
        error.hidden = false;
      }
    </script>
  </body>
</html>
