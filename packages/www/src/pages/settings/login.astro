<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Sign in — st.itch</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <main>
      <h1>Sign in</h1>
      <form id="login-form">
        <label>
          Handle
          <input type="text" name="handle" placeholder="alice.bsky.social" required autofocus />
        </label>
        <button type="submit">Continue</button>
      </form>
      <p id="error" role="alert" hidden></p>
    </main>
    <script>
      import { configure, startLogin } from '../../lib/oauth.ts';
      configure();
      const form = document.getElementById('login-form');
      const error = document.getElementById('error');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        error.hidden = true;
        const handle = new FormData(form).get('handle')?.toString().trim();
        if (!handle) return;
        try {
          await startLogin(handle);
        } catch (err) {
          error.textContent = err?.message ?? String(err);
          error.hidden = false;
        }
      });
    </script>
  </body>
</html>
